# =============================================================================
# Production Environment Configuration — TEMPLATE
# In production, ALL values are injected via Key Vault references or
# GitHub Actions secrets. Do not run production workloads from a local .env file.
# =============================================================================

AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000020
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000002

AZURE_KEY_VAULT_URL=https://kv-contosofabricprod.vault.azure.net/

ERP_SQL_SERVER=sql-contoso-fabric-prod.database.windows.net
ERP_SQL_DATABASE=erp_db_prod
ERP_SQL_PORT=1433
ERP_SQL_SECRET_NAME=erp-sql-sp-secret-prod
ERP_SQL_CONNECT_TIMEOUT=30
ERP_SQL_QUERY_TIMEOUT=7200

CTRL_SQL_SERVER=sql-contoso-fabric-prod.database.windows.net
CTRL_SQL_DATABASE=control_db_prod

FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000030
FABRIC_LAKEHOUSE_ID=00000000-0000-0000-0000-000000000031
FABRIC_WAREHOUSE_ID=00000000-0000-0000-0000-000000000032
FABRIC_API_TIMEOUT=120

LAKEHOUSE_ABFSS_PATH=abfss://contoso-analytics-lakehouse@onelake.dfs.fabric.microsoft.com/

LOG_LEVEL=INFO
LOG_FORMAT=json

ENABLE_DATA_QUALITY_CHECKS=true
ENABLE_ALERTING=true
DRY_RUN=false
