{
  "$schema": "https://developer.microsoft.com/fabric/schemas/table/1.0",
  "layer": "silver",
  "table_name": "sales_orders_cleansed",
  "schema": "silver",
  "description": "Cleansed and standardised sales orders. Duplicates removed, nulls handled, currency normalised to USD. Source-of-truth for order analytics.",
  "source_tables": ["bronze.sales_orders_raw"],
  "update_strategy": "merge_on_key",
  "partition_by": ["order_year", "order_month"],
  "delta_properties": {
    "delta.autoOptimize.optimizeWrite": "true",
    "delta.autoOptimize.autoCompact": "true",
    "delta.columnMapping.mode": "name",
    "delta.enableChangeDataFeed": "true",
    "delta.targetFileSize": "134217728"
  },
  "columns": [
    { "name": "order_id",             "type": "STRING",        "nullable": false, "description": "Surrogate order identifier" },
    { "name": "order_date",           "type": "DATE",          "nullable": false, "description": "Order creation date" },
    { "name": "order_year",           "type": "INT",           "nullable": false, "description": "Partition column — order year" },
    { "name": "order_month",          "type": "INT",           "nullable": false, "description": "Partition column — order month" },
    { "name": "customer_id",          "type": "STRING",        "nullable": false, "description": "Standardised customer ID" },
    { "name": "customer_name",        "type": "STRING",        "nullable": true,  "description": "Customer display name" },
    { "name": "product_id",           "type": "STRING",        "nullable": false, "description": "Standardised product ID" },
    { "name": "product_name",         "type": "STRING",        "nullable": true,  "description": "Product display name" },
    { "name": "category",             "type": "STRING",        "nullable": true,  "description": "Product category" },
    { "name": "quantity",             "type": "DECIMAL(18,4)", "nullable": false, "description": "Ordered quantity" },
    { "name": "unit_price_usd",       "type": "DECIMAL(18,4)", "nullable": false, "description": "Unit price in USD (FX converted)" },
    { "name": "total_amount_usd",     "type": "DECIMAL(18,4)", "nullable": false, "description": "Total order value in USD" },
    { "name": "original_currency",    "type": "STRING",        "nullable": true,  "description": "Source document currency" },
    { "name": "fx_rate_to_usd",       "type": "DECIMAL(18,6)", "nullable": true,  "description": "FX rate applied at conversion" },
    { "name": "status",               "type": "STRING",        "nullable": false, "description": "Standardised order status" },
    { "name": "region",               "type": "STRING",        "nullable": true,  "description": "Sales region code" },
    { "name": "sales_rep_id",         "type": "STRING",        "nullable": true,  "description": "Sales representative ID" },
    { "name": "_valid_from",          "type": "TIMESTAMP",     "nullable": false, "description": "SCD2 validity start" },
    { "name": "_valid_to",            "type": "TIMESTAMP",     "nullable": true,  "description": "SCD2 validity end (null = current)" },
    { "name": "_is_current",          "type": "BOOLEAN",       "nullable": false, "description": "SCD2 current record flag" },
    { "name": "_updated_ts",          "type": "TIMESTAMP",     "nullable": false, "description": "Last updated timestamp" },
    { "name": "_source_hash",         "type": "STRING",        "nullable": false, "description": "MD5 hash of source row for change detection" }
  ],
  "primary_key": ["order_id"],
  "merge_key": ["order_id"],
  "data_quality": {
    "not_null_columns": ["order_id", "order_date", "customer_id", "product_id", "quantity", "unit_price_usd"],
    "value_checks": [
      { "column": "quantity",         "check": "quantity > 0" },
      { "column": "unit_price_usd",   "check": "unit_price_usd >= 0" },
      { "column": "total_amount_usd", "check": "total_amount_usd >= 0" },
      { "column": "status",           "check": "status IN ('Completed', 'Pending', 'Cancelled', 'Refunded')" }
    ]
  },
  "tags": ["silver", "sales", "conformed", "scd2"]
}
