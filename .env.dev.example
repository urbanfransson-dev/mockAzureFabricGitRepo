# =============================================================================
# Development Environment Configuration — TEMPLATE
# Copy this file to .env and fill in your values.
# NEVER commit the .env file. Only commit this .env.dev.example template.
# =============================================================================

# ── Azure Identity ─────────────────────────────────────────────────────────────
# Service principal used for local development.
# In CI/CD and Fabric runtimes, use managed identity / OIDC instead.
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000001
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000002
# AZURE_CLIENT_SECRET — do NOT store here; use `az login` or Key Vault

# ── Azure Key Vault ────────────────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://kv-contosofabricdev.vault.azure.net/

# ── ERP SQL Database (Azure SQL) ───────────────────────────────────────────────
ERP_SQL_SERVER=sql-contoso-fabric-dev.database.windows.net
ERP_SQL_DATABASE=erp_db_dev
ERP_SQL_PORT=1433
ERP_SQL_SECRET_NAME=erp-sql-sp-secret
ERP_SQL_CONNECT_TIMEOUT=30
ERP_SQL_QUERY_TIMEOUT=3600

# ── Control Database (Azure SQL) ───────────────────────────────────────────────
CTRL_SQL_SERVER=sql-contoso-fabric-dev.database.windows.net
CTRL_SQL_DATABASE=control_db_dev

# ── Microsoft Fabric ───────────────────────────────────────────────────────────
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000003
FABRIC_LAKEHOUSE_ID=00000000-0000-0000-0000-000000000004
FABRIC_WAREHOUSE_ID=00000000-0000-0000-0000-000000000005
FABRIC_API_TIMEOUT=60
# Override API base only if using a sovereign cloud:
# FABRIC_API_BASE=https://api.fabric.microsoft.com/v1

# ── Lakehouse paths ────────────────────────────────────────────────────────────
LAKEHOUSE_ABFSS_PATH=abfss://contoso-analytics-lakehouse@onelake.dfs.fabric.microsoft.com/

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# ── Feature flags ──────────────────────────────────────────────────────────────
ENABLE_DATA_QUALITY_CHECKS=true
ENABLE_ALERTING=false
DRY_RUN=false
