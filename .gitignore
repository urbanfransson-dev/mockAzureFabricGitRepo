# ==============================================
# Microsoft Fabric / Azure Data Platform
# .gitignore
# ==============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/

# Environment variable files (NEVER commit secrets)
.env.local
.env.*.local
*.env
!*.env.example
!*.env.template

# Azure / Fabric credentials (NEVER commit)
*.pem
*.key
*.pfx
*.cer
*.crt
service_principal.json
azure_credentials.json
fabric_credentials.json

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# IDE
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Bicep / ARM compiled output
*.compiled.json

# Delta Lake / Parquet temp files
*.parquet.tmp
_delta_log/.tmp*
*.crc

# Spark
derby.log
metastore_db/
spark-warehouse/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.log
test-results/
coverage.xml

# Build artifacts
*.whl
*.tar.gz

# Temp
tmp/
temp/
*.tmp
*.bak
